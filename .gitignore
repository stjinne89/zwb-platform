# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (.env.local has credentials; .env.local.example is the safe template)
.env*
!.env.local.example

# scratch / one-off downloads (csv imports, dumps, etc.)
/.tmp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
