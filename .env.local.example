# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Team-resultaat sync (optioneel)
# Gebruik TEAM_RESULTS_SYNC_SECRET als Bearer token voor POST /api/team-results/sync.
TEAM_RESULTS_SYNC_SECRET=
ACHIEVEMENTS_SYNC_SECRET=
# EVENT_REMINDER_SECRET = Bearer voor POST /api/events/reminders.
# Externe cron (bv. cron-job.org) roept dit elke 15 min aan om 24u + 2u
# voor event-start push-notificaties te sturen naar RSVP-deelnemers.
EVENT_REMINDER_SECRET=
# TRAINING_ADAPTATION_SECRET = Bearer voor POST /api/training/adaptations/daily.
# Externe cron roept dit dagelijks aan om trainer-review drafts te maken.
TRAINING_ADAPTATION_SECRET=
# WTRL API geeft voor sommige endpoints 401 zonder ingelogde sessie-cookie.
# Vul alleen op server/hosting in als je expliciet een WTRL sessie wilt gebruiken.
WTRL_COOKIE=

# Club Ladder (ladder.cycleracing.club) /graveyard zit achter login.
# Log in, kopieer de connect.sid cookie via DevTools → Application → Cookies.
LADDER_COOKIE=

# Strava app credentials voor /achievements.
# Callback URL lokaal: http://localhost:3000/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# YouTube Data API key voor /media YouTube-sync.
# Maak gratis aan via console.cloud.google.com → APIs & Services → Credentials.
# Enable "YouTube Data API v3" in dat project.
YOUTUBE_API_KEY=

# Instagram Graph API voor /media Instagram-sync (@zwb_cycling).
# Gebruik de officiele Meta Instagram API met Instagram Login voor @zwb_cycling.
# INSTAGRAM_ACCESS_TOKEN is een long-lived Instagram User access token.
# INSTAGRAM_USER_ID is optioneel; als deze leeg is, probeert de sync /me te gebruiken.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_GRAPH_API_VERSION=v24.0
INSTAGRAM_GRAPH_API_BASE_URL=https://graph.instagram.com

# Podcast RSS-feed-URL voor automatische sync van afleveringen (optioneel).
# Te vinden in de podcast-host (Anchor, Buzzsprout, Podbean, Castos, Acast).
PODCAST_RSS_URL=

# Spotify Web API credentials — alleen nodig als je via Spotify API wilt syncen
# in plaats van via RSS. Registreer via developer.spotify.com → Dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (kalender / GPX, fase 1) — optioneel, we gebruiken nu OSM
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend (transactional email, fase 1+)
RESEND_API_KEY=

# Mollie (contributie, fase 3)
MOLLIE_API_KEY=

# Web Push notificaties (fase 3 — punt 16).
# Genereer eenmalig: npx web-push generate-vapid-keys
# Publieke key wordt aan de client meegegeven; private key blijft alleen
# serverside. VAPID_SUBJECT moet een mailto: of https://-URL zijn.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@zwbcycling.nl
