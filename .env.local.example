# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Versleuteling at rest van opgeslagen geheimen (Strava-tokens + intervals.icu
# API-keys). 32 bytes, base64. Genereer eenmalig: `openssl rand -base64 32`.
# Zonder deze sleutel blijft de app werken maar worden geheimen als plaintext
# opgeslagen (niet aanbevolen). Na het zetten: draai de backfill één keer via
# GET /api/admin/encrypt-secrets (ingelogd als beheerder).
TOKEN_ENCRYPTION_KEY=

# Team-resultaat sync (optioneel)
# Gebruik TEAM_RESULTS_SYNC_SECRET als Bearer token voor POST /api/team-results/sync.
TEAM_RESULTS_SYNC_SECRET=
ACHIEVEMENTS_SYNC_SECRET=
# STRAVA_SYNC_SECRET = Bearer voor POST /api/strava/sync.
# Externe cron roept dit bv. elke 15-30 min aan om gekoppelde atleten
# incrementeel bij te werken. Optioneel:
# - STRAVA_SYNC_MAX_PROFILES: aantal profielen per run.
# - STRAVA_SYNC_COL_SEGMENT_MAX_FETCHES: dure detailcalls per profiel voor
#   coltijden. Houd voor frequente cronruns standaard op 0.
# - STRAVA_SYNC_ZWB_SEGMENT_MAX_FETCHES: extra detailcalls per profiel voor
#   ZWB Segments. Houd voor frequente cronruns standaard op 0.
# - STRAVA_SYNC_RECONCILIATION_DAYS: recent venster waarin hernoemde en op
#   Strava verwijderde ritten worden bijgewerkt/opgeruimd.
STRAVA_SYNC_SECRET=
STRAVA_SYNC_MAX_PROFILES=20
STRAVA_SYNC_COL_SEGMENT_MAX_FETCHES=0
STRAVA_SYNC_ZWB_SEGMENT_MAX_FETCHES=0
STRAVA_SYNC_RECONCILIATION_DAYS=30
# EVENT_REMINDER_SECRET = Bearer voor POST /api/events/reminders.
# Externe cron (bv. cron-job.org) roept dit elke 15 min aan om 24u + 2u
# voor event-start push-notificaties te sturen naar RSVP-deelnemers.
EVENT_REMINDER_SECRET=
# TRAINING_ADAPTATION_SECRET = Bearer voor POST /api/training/adaptations/daily.
# Externe cron roept dit dagelijks aan om trainer-review drafts te maken.
TRAINING_ADAPTATION_SECRET=
# WTRL API geeft voor sommige endpoints 401 zonder ingelogde sessie-cookie.
# Vul alleen op server/hosting in als je expliciet een WTRL sessie wilt gebruiken.
WTRL_COOKIE=

# ZwiftGopher TTT planner API voor /teams/ttt-planner.
# Key aanmaken via https://zwiftgopher.com/api/dashboard.php.
ZWIFTGOPHER_API_KEY=
ZWIFTGOPHER_API_BASE_URL=https://zwiftgopher.com

# Club Ladder (ladder.cycleracing.club) /graveyard zit achter login.
# Log in, kopieer de connect.sid cookie via DevTools → Application → Cookies.
LADDER_COOKIE=

# Zwift-club-sync voor /beheer/event-scan (Increment 2). Gebruik een EIGEN
# ZWB-club-serviceaccount; credentials blijven serverside en worden nooit gelogd.
# Zonder deze drie blijft de eventscan gewoon werken (zonder clubsync).
# Verifieer de endpoints met de "Test clubkoppeling"-knop voordat je erop leunt.
ZWIFT_USERNAME=
ZWIFT_PASSWORD=
ZWIFT_CLUB_ID=
# Optionele overrides als de Zwift-API-paden afwijken van de defaults:
# ZWIFT_API_BASE=https://us-or-rly101.zwift.com/api
# ZWIFT_EVENT_FEED_PATH=event-feed
# ZWIFT_ENTRANTS_PATH=events/subgroups/entrants/{id}?type=all&participation=signed_up

# Strava app credentials voor /achievements.
# Callback URL lokaal: http://localhost:3000/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# YouTube Data API key voor /media YouTube-sync.
# Maak gratis aan via console.cloud.google.com → APIs & Services → Credentials.
# Enable "YouTube Data API v3" in dat project.
YOUTUBE_API_KEY=

# Instagram Graph API voor /media Instagram-sync (@zwb_cycling).
# Gebruik de officiele Meta Instagram API met Instagram Login voor @zwb_cycling.
# INSTAGRAM_ACCESS_TOKEN is een long-lived Instagram User access token.
# INSTAGRAM_USER_ID is optioneel; als deze leeg is, probeert de sync /me te gebruiken.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_GRAPH_API_VERSION=v24.0
INSTAGRAM_GRAPH_API_BASE_URL=https://graph.instagram.com

# Podcast RSS-feed-URL voor automatische sync van afleveringen (optioneel).
# Te vinden in de podcast-host (Anchor, Buzzsprout, Podbean, Castos, Acast).
PODCAST_RSS_URL=

# Spotify Web API credentials — alleen nodig als je via Spotify API wilt syncen
# in plaats van via RSS. Registreer via developer.spotify.com → Dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI voor trainings-AI.
# De cockpit gebruikt background mode, dus dit mag het beste/zwaarste model zijn.
OPENAI_API_KEY=
OPENAI_TRAINING_MODEL=gpt-5.5

# Mapbox (kalender / GPX, fase 1) — optioneel, we gebruiken nu OSM
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend (transactional email, fase 1+)
RESEND_API_KEY=

# Mollie (contributie, fase 3)
MOLLIE_API_KEY=

# Web Push notificaties (fase 3 — punt 16).
# Genereer eenmalig: npx web-push generate-vapid-keys
# Publieke key wordt aan de client meegegeven; private key blijft alleen
# serverside. VAPID_SUBJECT moet een mailto: of https://-URL zijn.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@zwbcycling.nl
