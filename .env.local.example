# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Team-resultaat sync (optioneel)
# Gebruik TEAM_RESULTS_SYNC_SECRET als Bearer token voor POST /api/team-results/sync.
TEAM_RESULTS_SYNC_SECRET=
ACHIEVEMENTS_SYNC_SECRET=
# WTRL API geeft voor sommige endpoints 401 zonder ingelogde sessie-cookie.
# Vul alleen op server/hosting in als je expliciet een WTRL sessie wilt gebruiken.
WTRL_COOKIE=

# Strava app credentials voor /achievements.
# Callback URL lokaal: http://localhost:3000/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# YouTube Data API key voor /media YouTube-sync.
# Maak gratis aan via console.cloud.google.com → APIs & Services → Credentials.
# Enable "YouTube Data API v3" in dat project.
YOUTUBE_API_KEY=

# Spotify Web API credentials voor podcast-sync (optioneel).
# Registreer een app via developer.spotify.com → Dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (kalender / GPX, fase 1) — optioneel, we gebruiken nu OSM
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend (transactional email, fase 1+)
RESEND_API_KEY=

# Mollie (contributie, fase 3)
MOLLIE_API_KEY=
